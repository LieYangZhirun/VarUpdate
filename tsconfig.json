{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@vendor/promptal-yaml": ["./vendor/promptal-yaml/src/index.ts"],
      "@vendor/schema-to-zod": ["./vendor/schema-to-zod/src/index.ts"],
      "@vendor/flexible-json-patch": ["./vendor/flexible-json-patch/src/index.ts"]
    }
  },
  "include": ["src/**/*", "vendor/**/*.ts"],
  "exclude": ["node_modules"]
}
